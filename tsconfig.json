{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@wick-charts/core": ["./packages/core/src/index.ts"],
      "@wick-charts/react": ["./packages/react/src/index.ts"],
      "@wick-charts/vue": ["./packages/vue/src/index.ts"],
      "@wick-charts/svelte": ["./packages/svelte/src/index.ts"]
    }
  },
  "include": ["packages", "docs"]
}
