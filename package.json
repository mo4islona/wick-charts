{
  "name": "wick-charts",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "pnpm -r build",
    "build:docs": "vite build --mode docs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench": "vitest bench --run",
    "size": "node scripts/bundle-size.mjs",
    "readme": "node scripts/generate-readmes.mjs",
    "publish:all": "pnpm -r build && pnpm -r --filter './packages/*' publish --access public"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@sveltejs/vite-plugin-svelte": "^3.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.5.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "esbuild": "0.21.5",
    "happy-dom": "^20.9.0",
    "jsdom": "^29.0.2",
    "lucide-react": "^1.7.0",
    "prismjs": "^1.30.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "svelte": "^4.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^2.1.9",
    "vue": "^3.4.0"
  }
}
